    { "type": "Notebook",      "name": "03_model_evaluation",     "definitionPath": "notebooks/ml/03_model_evaluation.ipynb",      "order": 3 },
    { "type": "Notebook",      "name": "04_batch_scoring",        "definitionPath": "notebooks/ml/04_batch_scoring.ipynb",         "order": 4 },
    { "type": "SemanticModel", "name": "predictions_model",       "definitionPath": "tmdl" },
