  "estimatedTime": "15-20 min",
  "tags": ["ml", "anomaly", "alerts", "lakehouse"],
  "prerequisites": [
    "Fabric capacity (F2+, Trial, or PPU)"
  ],
  "azureParams": [],
  "fabricItemTemplate": [
    { "type": "Lakehouse",     "name": "analytics_lakehouse" },
    { "type": "Notebook",      "name": "01_bronze_ingest",       "definitionPath": "notebooks/batch/01_bronze_ingest.ipynb",        "order": 1 },
    { "type": "Notebook",      "name": "02_silver_transform",    "definitionPath": "notebooks/batch/02_silver_transform.ipynb",     "order": 2 },
    { "type": "Notebook",      "name": "03_anomaly_detection",   "definitionPath": "notebooks/ml/03_anomaly_detection.ipynb",       "order": 3 },
    { "type": "Notebook",      "name": "04_alert_pipeline",      "definitionPath": "notebooks/ml/04_alert_pipeline.ipynb",          "order": 4 },
    { "type": "SemanticModel", "name": "anomaly_model",          "definitionPath": "tmdl" },
