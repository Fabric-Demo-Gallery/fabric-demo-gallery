  "explore": {
    "title": "Average length of stay and admission volume by department",
    "sql": "SELECT a.department, COUNT(*) AS admissions, ROUND(AVG(CAST(a.length_of_stay_days AS FLOAT)), 1) AS avg_los_days, SUM(CASE WHEN a.is_readmission = 1 THEN 1 ELSE 0 END) AS readmissions FROM m_patient_admissions a GROUP BY a.department ORDER BY admissions DESC"
  },
