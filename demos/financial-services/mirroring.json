  "explore": {
    "title": "Transaction value and flagged-fraud rate by merchant category",
    "sql": "SELECT t.merchant_category, COUNT(*) AS transactions, ROUND(SUM(t.amount), 0) AS total_amount, SUM(CASE WHEN t.is_flagged_fraud = 1 THEN 1 ELSE 0 END) AS flagged_fraud FROM m_transactions t GROUP BY t.merchant_category ORDER BY total_amount DESC"
  },
  "liveChange": {
    "table": "transactions",
    "keyColumn": "transaction_id",
    "displayColumn": "merchant_category",
    "mutateColumn": "is_flagged_fraud",
    "mutateKind": "flag",
    "flagTo": 1,
    "story": "A fraud analyst flags a suspicious transaction in the source banking system. Watch the fraud flag replicate into Fabric in seconds, ready for downstream risk analytics, with no pipeline or refresh."
  }
