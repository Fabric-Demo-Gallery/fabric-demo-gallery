  "explore": {
    "title": "Completion and withdrawal rates by department",
    "sql": "SELECT e.department, COUNT(*) AS enrolments, SUM(CASE WHEN e.is_completed = 1 THEN 1 ELSE 0 END) AS completed, SUM(CASE WHEN e.is_withdrawn = 1 THEN 1 ELSE 0 END) AS withdrawn, ROUND(100.0 * SUM(CASE WHEN e.is_withdrawn = 1 THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0), 2) AS withdrawal_rate_pct FROM m_enrolments e GROUP BY e.department ORDER BY withdrawal_rate_pct DESC"
  },
