  "explore": {
    "title": "On-time performance and delay by route",
    "sql": "SELECT r.origin, r.destination, COUNT(*) AS deliveries, SUM(CASE WHEN d.is_late = 1 THEN 1 ELSE 0 END) AS late_deliveries, ROUND(AVG(d.delay_hrs), 2) AS avg_delay_hrs FROM m_deliveries d JOIN m_routes r ON d.route_id = r.route_id GROUP BY r.origin, r.destination ORDER BY late_deliveries DESC"
  },
  "liveChange": {
    "table": "deliveries",
    "keyColumn": "delivery_id",
    "displayColumn": "status",
    "mutateColumn": "is_late",
    "mutateKind": "flag",
    "flagTo": 1,
    "story": "A dispatcher flags a delivery as late in the source transport-management system. Watch the flag replicate into Fabric in seconds, updating the on-time-performance dashboard, with no pipeline or refresh."
  }
